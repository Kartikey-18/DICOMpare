<Window x:Class="DiCOMpare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DiCOMpare.Converters"
        Title="DiCOMpare - DICOM Tag Comparison Tool"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <conv:SafetyToColorConverter x:Key="SafetyToColor"/>
        <conv:SafetyToLabelConverter x:Key="SafetyToLabel"/>
        <conv:SafetyToBackgroundConverter x:Key="SafetyToBackground"/>
        <conv:MatchStatusToColorConverter x:Key="StatusToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:VerdictToColorConverter x:Key="VerdictToColor"/>

        <!-- Dark theme styles -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BrowseButton" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#585B70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="FilterTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="DiCOMpare" FontSize="24" FontWeight="Bold" Foreground="#89B4FA"/>
            <TextBlock Text="DICOM Tag Comparison and Safety Analysis" FontSize="12" Foreground="#6C7086" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Study loaders - side by side -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left study -->
            <Border Grid.Column="0" Background="#181825" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="SOURCE STUDY (Rejected)" Style="{StaticResource HeaderText}" Foreground="#F38BA8" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse Folder" Style="{StaticResource BrowseButton}" Click="BrowseLeft_Click" Margin="8,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="Browse File" Style="{StaticResource BrowseButton}" Click="BrowseLeftFile_Click" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource PathTextBox}" Text="{Binding LeftPath, Mode=OneWay}" AllowDrop="True" Drop="LeftDrop" DragOver="DragOverHandler"/>
                    </DockPanel>
                    <TextBlock Text="{Binding LeftStudySummary}" FontSize="11" Foreground="#A6ADC8" FontFamily="Consolas" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Right study -->
            <Border Grid.Column="2" Background="#181825" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="REFERENCE STUDY (Accepted)" Style="{StaticResource HeaderText}" Foreground="#A6E3A1" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse Folder" Style="{StaticResource BrowseButton}" Click="BrowseRight_Click" Margin="8,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="Browse File" Style="{StaticResource BrowseButton}" Click="BrowseRightFile_Click" Margin="8,0,0,0"/>
                        <TextBox Style="{StaticResource PathTextBox}" Text="{Binding RightPath, Mode=OneWay}" AllowDrop="True" Drop="RightDrop" DragOver="DragOverHandler"/>
                    </DockPanel>
                    <TextBlock Text="{Binding RightStudySummary}" FontSize="11" Foreground="#A6ADC8" FontFamily="Consolas" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Verdict banner -->
        <Border Grid.Row="2" Background="#181825" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding VerdictText}" FontSize="14" FontWeight="Bold"
                           Foreground="{Binding VerdictText, Converter={StaticResource VerdictToColor}}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SummaryText}" FontSize="12" Foreground="#A6ADC8" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Grid Grid.Row="3" Margin="0,0,0,8"
              Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource FilterTextBox}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     x:Name="FilterBox"/>
            <CheckBox Grid.Column="1" Content="Show only differences" Margin="12,0,0,0"
                      Foreground="#CDD6F4" VerticalAlignment="Center" FontSize="13"
                      IsChecked="{Binding ShowOnlyDifferences}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <CheckBox Content="Redact PHI" Margin="12,0,0,0" x:Name="RedactPhiCheckbox"
                          Foreground="#F38BA8" VerticalAlignment="Center" FontSize="13"
                          IsChecked="True"/>
                <Button Content="Export Report" Style="{StaticResource BrowseButton}"
                        Click="ExportReport_Click" Margin="12,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Comparison table -->
        <Border Grid.Row="4" Background="#181825" CornerRadius="8" Padding="0"
                Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <DataGrid ItemsSource="{Binding FilteredRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#313244"
                      Background="Transparent"
                      Foreground="#CDD6F4"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#1B1B2B"
                      FontSize="12"
                      FontFamily="Consolas"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      RowHeight="28"
                      ColumnHeaderHeight="32">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#313244"/>
                        <Setter Property="Foreground" Value="#89B4FA"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="#45475A"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="6,4">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#45475A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="ToolTip" Value="{Binding SafetyReason}"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Safety indicator -->
                    <DataGridTemplateColumn Header="Safety" Width="80" SortMemberPath="Safety">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Safety, Converter={StaticResource SafetyToColor}}"
                                        CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Safety, Converter={StaticResource SafetyToLabel}}"
                                               Foreground="White" FontSize="10" FontWeight="Bold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Tag -->
                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#89B4FA"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tag Name -->
                    <DataGridTextColumn Header="Name" Binding="{Binding TagName}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Left value -->
                    <DataGridTextColumn Header="Source (Left)" Binding="{Binding LeftValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#F38BA8"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Right value -->
                    <DataGridTextColumn Header="Reference (Right)" Binding="{Binding RightValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#A6E3A1"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontSize="11"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                           FontFamily="Segoe UI"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="5" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#6C7086"/>
        </Border>

        <!-- Legend (always visible) -->
        <StackPanel Grid.Row="5" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,8,0,0">
            <Border Background="#2EA043" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="SAFE" Foreground="White" FontSize="9" FontWeight="Bold"/>
            </Border>
            <TextBlock Text="No clinical impact" FontSize="10" Foreground="#6C7086" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <Border Background="#D29922" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="CAUTION" Foreground="White" FontSize="9" FontWeight="Bold"/>
            </Border>
            <TextBlock Text="Review needed" FontSize="10" Foreground="#6C7086" VerticalAlignment="Center" Margin="0,0,16,0"/>

            <Border Background="#DA3633" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                <TextBlock Text="UNSAFE" Foreground="White" FontSize="9" FontWeight="Bold"/>
            </Border>
            <TextBlock Text="Affects measurements" FontSize="10" Foreground="#6C7086" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
