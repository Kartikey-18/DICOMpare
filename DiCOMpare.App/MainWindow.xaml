<Window x:Class="DiCOMpare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DiCOMpare.Converters"
        Title="DiCOMpare - DICOM Tag Comparison Tool"
        Height="900" Width="1400"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{Binding Theme.WindowBackground}">

    <Window.Resources>
        <conv:SafetyToColorConverter x:Key="SafetyToColor"/>
        <conv:SafetyToLabelConverter x:Key="SafetyToLabel"/>
        <conv:SafetyToBackgroundConverter x:Key="SafetyToBackground"/>
        <conv:MatchStatusToColorConverter x:Key="StatusToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:VerdictToColorConverter x:Key="VerdictToColor"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar with theme toggle -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="{Binding Theme.ToggleLabel}" Click="ToggleTheme_Click"
                        Padding="12,6" FontSize="12" Cursor="Hand"
                        Background="{Binding Theme.ButtonBackground}"
                        Foreground="{Binding Theme.TextPrimary}"
                        BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="DiCOMpare" FontSize="24" FontWeight="Bold" Foreground="{Binding Theme.AccentBlue}"/>
                <TextBlock Text="DICOM Tag Comparison and Safety Analysis" FontSize="12"
                           Foreground="{Binding Theme.TextMuted}" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Study loaders - side by side -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left study -->
            <Border Grid.Column="0" Background="{Binding Theme.PanelBackground}" CornerRadius="8" Padding="12"
                    BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="SOURCE STUDY (Rejected)" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding Theme.AccentRed}" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse Folder" Click="BrowseLeft_Click" Margin="8,0,0,0"
                                Padding="16,8" FontSize="13" Cursor="Hand"
                                Background="{Binding Theme.ButtonBackground}"
                                Foreground="{Binding Theme.TextPrimary}"
                                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button DockPanel.Dock="Right" Content="Browse File" Click="BrowseLeftFile_Click" Margin="8,0,0,0"
                                Padding="16,8" FontSize="13" Cursor="Hand"
                                Background="{Binding Theme.ButtonBackground}"
                                Foreground="{Binding Theme.TextPrimary}"
                                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBox IsReadOnly="True" Text="{Binding LeftPath, Mode=OneWay}" AllowDrop="True"
                                 Drop="LeftDrop" DragOver="DragOverHandler"
                                 Background="{Binding Theme.InputBackground}"
                                 Foreground="{Binding Theme.TextSecondary}"
                                 BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1"
                                 Padding="8,6" FontSize="12"/>
                    </DockPanel>
                    <TextBlock Text="{Binding LeftStudySummary}" FontSize="11"
                               Foreground="{Binding Theme.TextSecondary}" FontFamily="Consolas" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Right study -->
            <Border Grid.Column="2" Background="{Binding Theme.PanelBackground}" CornerRadius="8" Padding="12"
                    BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="REFERENCE STUDY (Accepted)" FontSize="14" FontWeight="SemiBold"
                               Foreground="{Binding Theme.AccentGreen}" Margin="0,0,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Browse Folder" Click="BrowseRight_Click" Margin="8,0,0,0"
                                Padding="16,8" FontSize="13" Cursor="Hand"
                                Background="{Binding Theme.ButtonBackground}"
                                Foreground="{Binding Theme.TextPrimary}"
                                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button DockPanel.Dock="Right" Content="Browse File" Click="BrowseRightFile_Click" Margin="8,0,0,0"
                                Padding="16,8" FontSize="13" Cursor="Hand"
                                Background="{Binding Theme.ButtonBackground}"
                                Foreground="{Binding Theme.TextPrimary}"
                                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBox IsReadOnly="True" Text="{Binding RightPath, Mode=OneWay}" AllowDrop="True"
                                 Drop="RightDrop" DragOver="DragOverHandler"
                                 Background="{Binding Theme.InputBackground}"
                                 Foreground="{Binding Theme.TextSecondary}"
                                 BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1"
                                 Padding="8,6" FontSize="12"/>
                    </DockPanel>
                    <TextBlock Text="{Binding RightStudySummary}" FontSize="11"
                               Foreground="{Binding Theme.TextSecondary}" FontFamily="Consolas" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Verdict banner -->
        <Border Grid.Row="2" Background="{Binding Theme.PanelBackground}" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1"
                Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding VerdictText}" FontSize="14" FontWeight="Bold"
                           Foreground="{Binding VerdictText, Converter={StaticResource VerdictToColor}}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SummaryText}" FontSize="12"
                           Foreground="{Binding Theme.TextSecondary}" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Grid Grid.Row="3" Margin="0,0,0,8"
              Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="FilterBox"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Background="{Binding Theme.InputBackground}"
                     Foreground="{Binding Theme.TextPrimary}"
                     BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1"
                     Padding="8,6" FontSize="13" CaretBrush="{Binding Theme.TextPrimary}"/>
            <CheckBox Grid.Column="1" Content="Show only differences" Margin="12,0,0,0"
                      Foreground="{Binding Theme.TextPrimary}" VerticalAlignment="Center" FontSize="13"
                      IsChecked="{Binding ShowOnlyDifferences}"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <CheckBox Content="Redact PHI" Margin="12,0,0,0" x:Name="RedactPhiCheckbox"
                          Foreground="{Binding Theme.AccentRed}" VerticalAlignment="Center" FontSize="13"
                          IsChecked="True"/>
                <Button Content="Export Report" Click="ExportReport_Click" Margin="12,0,0,0"
                        Padding="16,8" FontSize="13" Cursor="Hand"
                        Background="{Binding Theme.ButtonBackground}"
                        Foreground="{Binding Theme.TextPrimary}"
                        BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Comparison table -->
        <Border Grid.Row="4" Background="{Binding Theme.PanelBackground}" CornerRadius="8" Padding="0"
                BorderBrush="{Binding Theme.BorderColor}" BorderThickness="1"
                Visibility="{Binding IsCompared, Converter={StaticResource BoolToVis}}">
            <DataGrid ItemsSource="{Binding FilteredRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{Binding Theme.GridLine}"
                      Background="Transparent"
                      Foreground="{Binding Theme.TextPrimary}"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{Binding Theme.RowAlt}"
                      FontSize="12"
                      FontFamily="Consolas"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      RowHeight="28"
                      ColumnHeaderHeight="32">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{Binding DataContext.Theme.HeaderBackground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="Foreground" Value="{Binding DataContext.Theme.AccentBlue, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderBrush" Value="{Binding DataContext.Theme.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="6,4">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{Binding DataContext.Theme.SelectedRow, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="ToolTip" Value="{Binding SafetyReason}"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Safety indicator -->
                    <DataGridTemplateColumn Header="Safety" Width="80" SortMemberPath="Safety">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Safety, Converter={StaticResource SafetyToColor}}"
                                        CornerRadius="3" Padding="4,1" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Safety, Converter={StaticResource SafetyToLabel}}"
                                               Foreground="White" FontSize="10" FontWeight="Bold"
                                               FontFamily="Segoe UI"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Tag -->
                    <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding DataContext.Theme.AccentBlue, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Tag Name -->
                    <DataGridTextColumn Header="Name" Binding="{Binding TagName}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding DataContext.Theme.TextPrimary, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Left value -->
                    <DataGridTextColumn Header="Source (Left)" Binding="{Binding LeftValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding DataContext.Theme.AccentRed, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Right value -->
                    <DataGridTextColumn Header="Reference (Right)" Binding="{Binding RightValue}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding DataContext.Theme.AccentGreen, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Status -->
                    <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontSize="11"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                           FontFamily="Segoe UI"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar and legend -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{Binding Theme.TextMuted}"
                       HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Border Background="#2EA043" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="SAFE" Foreground="White" FontSize="9" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="No clinical impact" FontSize="10" Foreground="{Binding Theme.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Border Background="#D29922" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="CAUTION" Foreground="White" FontSize="9" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="Review needed" FontSize="10" Foreground="{Binding Theme.TextMuted}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <Border Background="#DA3633" CornerRadius="3" Padding="6,2" Margin="0,0,8,0">
                    <TextBlock Text="UNSAFE" Foreground="White" FontSize="9" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="Affects measurements" FontSize="10" Foreground="{Binding Theme.TextMuted}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
